{
	"author": {
		"name": "Kevin Peckham"
	},
	"bugs": {
		"url": "https://github.com/kevinpeckham/woof-editor/issues"
	},
	"description": "Barkdown-backed contenteditable markdown editor for Svelte 5. Round-trip WYSIWYG on marked, with menus, link popover, and footnote support. Companion to @kevinpeckham/barkdown.",
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@kevinpeckham/barkdown": "^0.1.1",
		"@storybook/addon-a11y": "^10.5.2",
		"@storybook/addon-docs": "^10.5.2",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.5.2",
		"@storybook/sveltekit": "^10.5.2",
		"@sveltejs/adapter-auto": "^6.1.1",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/package": "^2.5.5",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^24.13.3",
		"@vitest/browser-playwright": "^4.1.10",
		"fallow": "^3.7.1",
		"happy-dom": "^20.11.0",
		"isomorphic-dompurify": "^2.28.0",
		"marked": "^18.0.0",
		"marked-footnote": "^1.4.0",
		"playwright": "^1.61.1",
		"publint": "^0.3.16",
		"storybook": "^10.5.2",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"typescript": "^6.0.3",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^3.0.0"
	},
	"engines": {
		"bun": "1.x",
		"node": "24.x"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"homepage": "https://github.com/kevinpeckham/woof-editor#readme",
	"keywords": [
		"markdown",
		"wysiwyg",
		"contenteditable",
		"svelte",
		"svelte-5",
		"marked",
		"barkdown",
		"editor",
		"gfm",
		"footnotes"
	],
	"license": "MIT",
	"name": "@kevinpeckham/woof-editor",
	"peerDependencies": {
		"@kevinpeckham/barkdown": "^0",
		"isomorphic-dompurify": "^2",
		"marked": "^18",
		"marked-footnote": "^1.4",
		"svelte": "^5"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kevinpeckham/woof-editor.git"
	},
	"scripts": {
		"audit": "bunx fallow audit",
		"biome": "bunx biome check --write .",
		"biome:ci": "bunx biome ci .",
		"build": "svelte-kit sync && svelte-package && publint",
		"build-storybook": "storybook build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"dev": "storybook dev -p 6006",
		"prepare": "svelte-kit sync || echo ''",
		"prepublishOnly": "bun run check && bun run test && bun run build",
		"storybook": "storybook dev -p 6006",
		"test": "vitest --run",
		"test:watch": "vitest"
	},
	"svelte": "./dist/index.js",
	"type": "module",
	"types": "./dist/index.d.ts",
	"version": "0.1.0"
}
